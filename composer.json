{
    "name": "stellarwp/foundation",
    "description": "Foundation is a StellarWP monorepo",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "StellarWP",
            "homepage": "https://stellarwp.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-curl": "*",
        "ext-exif": "*",
        "adbario/php-dot-notation": ">=2.5",
        "lucatume/di52": ">=3.0",
        "monolog/monolog": "^2.11",
        "psr/log": ">=1.0",
        "stellarwp/container-contract": "^1.1",
        "symfony/console": ">=5.4",
        "vlucas/phpdotenv": ">=4.3"
    },
    "require-dev": {
        "lucatume/wp-browser": "^4.5",
        "monorepo-php/monorepo": "^12.7",
        "nunomaduro/collision": "^8.9",
        "php-mock/php-mock-mockery": "^1.5",
        "php-stubs/wordpress-stubs": ">=6.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.5",
        "wp-cli/wp-cli": ">=2.12",
        "zenphp/pinte": "^1.2"
    },
    "replace": {
        "stellarwp/foundation-cli": "self.version",
        "stellarwp/foundation-container": "self.version",
        "stellarwp/foundation-container-wordpress": "self.version",
        "stellarwp/foundation-log": "self.version",
        "stellarwp/foundation-pipeline": "self.version",
        "stellarwp/foundation-wpcli": "self.version"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "StellarWP\\Foundation\\Cli\\": "src/Cli/",
            "StellarWP\\Foundation\\Container\\": "src/Container/",
            "StellarWP\\Foundation\\ContainerWordPress\\": "src/ContainerWordPress/",
            "StellarWP\\Foundation\\Log\\": "src/Log/",
            "StellarWP\\Foundation\\Pipeline\\": "src/Pipeline/",
            "StellarWP\\Foundation\\WPCli\\": "src/WPCli/"
        },
        "exclude-from-classmap": [
            "src/*/vendor/",
            "tests/CodeceptionSupport/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "StellarWP\\Foundation\\Tests\\": "tests/",
            "StellarWP\\Foundation\\Tests\\WPUnit\\": "tests/wpunit/"
        }
    },
    "bin": [
        "src/Cli/bin/foundation"
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "foundation": "@php src/Cli/bin/foundation",
        "monorepo": "@php vendor/bin/monorepo-builder",
        "test": "@php vendor/bin/phpunit -c phpunit.xml.dist --colors=always -d memory_limit=2G",
        "test:unit": "@test --testsuite Unit",
        "test:feature": "@test --testsuite Feature",
        "test:slic": "slic run",
        "test:slic:unit": "slic run unit",
        "test:slic:feature": "slic run feature",
        "test:wpunit": "slic run wpunit",
        "test:coverage": "slic xdebug on && slic run --coverage --coverage-xml clover.xml --disable-coverage-php; status=$?; slic xdebug off; exit $status",
        "test:coverage-html": "slic xdebug on && slic run --coverage --coverage-html coverage --disable-coverage-php; status=$?; slic xdebug off; exit $status",
        "analyze": "@php vendor/bin/phpstan analyse --ansi --memory-limit 2G",
        "lint": "@php vendor/bin/pinte --test -v",
        "format": "@php vendor/bin/pinte -v"
    },
    "scripts-descriptions": {
        "foundation": "Run the Foundation developer CLI.",
        "monorepo": "Run the Monorepo Builder CLI.",
        "test": "Run the fast PHPUnit unit and feature suites.",
        "test:unit": "Run the PHPUnit unit suite.",
        "test:feature": "Run the PHPUnit feature suite.",
        "test:slic": "Run all Codeception suites through SLIC.",
        "test:slic:unit": "Run the Codeception unit suite through SLIC.",
        "test:slic:feature": "Run the Codeception feature suite through SLIC.",
        "test:wpunit": "Run the WordPress-loaded wpunit suite through SLIC.",
        "test:coverage": "Generate combined SLIC/Codeception Clover coverage, then turn Xdebug off.",
        "test:coverage-html": "Generate combined SLIC/Codeception HTML coverage, then turn Xdebug off.",
        "analyze": "Run PHPStan static analysis.",
        "lint": "Check code style with Pinte.",
        "format": "Fix code style with Pinte."
    }
}
